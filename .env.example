# ─────────────────────────────────────────────────────────────────────────────
# SENTINEL environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────────────────────
# "cascade"      — Groq first, auto-falls back to HuggingFace when quota runs out (recommended)
# "groq"         — free cloud API, fast; daily quota resets at midnight UTC
# "huggingface"  — free cloud API, no hard daily quota
# "ollama"       — local, free, no API key (needs a GPU or fast CPU)
# "anthropic"    — paid API (optional)
LLM_PROVIDER=cascade

# ── Ollama (no API key needed) ────────────────────────────────────────────────
# Install Ollama: https://ollama.com  then pull models:
#   ollama pull qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_STRONG=qwen2.5-coder:7b
OLLAMA_MODEL_FAST=qwen2.5-coder:7b

# ── Groq (primary — fast, free) ──────────────────────────────────────────────
# Required for LLM_PROVIDER=groq or LLM_PROVIDER=cascade
# Get a free key at: https://console.groq.com (no credit card)
GROQ_API_KEY=gsk_...
# GROQ_MODEL_STRONG=llama-3.3-70b-versatile
# GROQ_MODEL_FAST=llama-3.1-8b-instant

# ── HuggingFace (fallback — free, no hard daily quota) ───────────────────────
# Required for LLM_PROVIDER=huggingface or LLM_PROVIDER=cascade
# In cascade mode: Groq is tried first; HuggingFace is used automatically when
# Groq's rate limit is hit — no action needed from the user.
# 1. Sign up at https://huggingface.co (free)
# 2. Go to https://huggingface.co/settings/tokens → New token (Read permission)
HUGGINGFACE_API_KEY=hf_...
# HF_MODEL_STRONG=Qwen/Qwen2.5-72B-Instruct
# HF_MODEL_FAST=Qwen/Qwen2.5-7B-Instruct

# ── Anthropic (paid — optional) ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL_STRONG=claude-sonnet-4-6
# LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./keys/github-app.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# Optional: personal access token for simple single-repo setups
GITHUB_TOKEN=ghp_...

# ── Chroma vector store ───────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=sentinel_kb

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Secret used to sign internal API tokens
API_SECRET_KEY=change-me-to-a-long-random-string
# Allowed Host header values. Use "*" for local dev.
# In production set to your domain(s): sentinel.example.com,api.example.com
TRUSTED_HOSTS=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Docker sandbox ────────────────────────────────────────────────────────────
SANDBOX_IMAGE=sentinel-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_MEMORY_LIMIT=1g
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=50000

# ── Knowledge base maintenance ────────────────────────────────────────────────
KB_CONFIDENCE_DECAY_DAYS=30
KB_CONFIDENCE_THRESHOLD=0.3
KB_CURATOR_REJECTION_THRESHOLD=3
# Cron schedule for nightly maintenance (default: 02:00 daily)
KB_MAINTENANCE_CRON=0 2 * * *

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/sentinel.log

# ── Risk scoring thresholds ───────────────────────────────────────────────────
RISK_HIGH_THRESHOLD=0.7
RISK_MEDIUM_THRESHOLD=0.4
# Files matching these patterns always score High risk
RISK_SENSITIVE_PATTERNS=auth,payment,billing,secret,credential,password,token,admin,migrations
